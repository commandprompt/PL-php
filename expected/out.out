CREATE SCHEMA plphp;
-- check an SRF with multiple OUT arguments.
CREATE OR REPLACE FUNCTION plphp.multiple_out(number OUT INTEGER, prefered OUT TEXT) RETURNS SETOF RECORD
AS $$
	$result = array(	
		array(0, 'zero'),
		array(1, 'ichi'),
		array(2, 'ni'),
		array(3, 'san'),
		array(4, 'yon'),
		array(5, 'go'),
		array(6, 'roku'),
		array(7, 'nana'),
		array(8, 'hachi'),
		array(9, 'ku'));
	for ($i = 0; $i < 9; $i++) {
		return_next($result[$i]);
	}
	return;
$$ LANGUAGE plphp;
SELECT * FROM plphp.multiple_out(); 
 number | prefered 
--------+----------
      0 | zero
      1 | ichi
      2 | ni
      3 | san
      4 | yon
      5 | go
      6 | roku
      7 | nana
      8 | hachi
(9 rows)

-- check that INOUT and OUT arguments can be used together.
CREATE OR REPLACE FUNCTION plphp.inout(s OUT INTEGER, a INOUT INTEGER, b INOUT INTEGER) 
AS $$
	$s = $a;
	$a = $b;
	$b = $s;
	$s += $a;
$$ LANGUAGE plphp;
SELECT * FROM plphp.inout(24, 42);
 s  | a  | b  
----+----+----
 66 | 42 | 24
(1 row)

-- check TABLE arguments. Make sure that both return_next(array) and return_next()
-- work when TABLE arguments are declared.
CREATE OR REPLACE FUNCTION plphp.table_out(lim INTEGER) RETURNS TABLE(number INTEGER, square INTEGER) AS
$$
	for ($number = 1; $number <= $lim; $number++) {
		$square = $number * $number;
		if ($number % 2)
			return_next();
		else
			return_next(array($number, $square));
	}
$$ LANGUAGE plphp;
SELECT * FROM plphp.table_out(10);
 number | square 
--------+--------
      1 |      1
      2 |      4
      3 |      9
      4 |     16
      5 |     25
      6 |     36
      7 |     49
      8 |     64
      9 |     81
     10 |    100
(10 rows)

-- check an OUT function returning invalid values 
CREATE OR REPLACE FUNCTION plphp.out_invalid(a OUT INTEGER, "long identifier" OUT INTEGER) AS
$$
 
  return(array(1,2));
$$ LANGUAGE plphp;
SELECT * FROM plphp.out_invalid();
ERROR:  "long identifier" can not be used as a PHP variable name
-- INOUT parameters in procedures: a procedure's result is always a record
-- (even with one INOUT), returned via the same assignment convention
CREATE PROCEDURE proc_one(INOUT x int) LANGUAGE plphp AS $$
    $x = $x + 1;
$$;
CALL proc_one(41);
 x  
----
 42
(1 row)

CREATE PROCEDURE proc_multi(INOUT x int, INOUT y text) LANGUAGE plphp AS $$
    $x = $x * 2;
    $y = strrev($y);
$$;
CALL proc_multi(21, 'ko');
 x  | y  
----+----
 42 | ok
(1 row)

CREATE PROCEDURE proc_mixed(IN a int, INOUT total int) LANGUAGE plphp AS $$
    $total = $a + $total;
$$;
CALL proc_mixed(40, 2);
 total 
-------
    42
(1 row)

-- returning an explicit array works too
CREATE PROCEDURE proc_ret(INOUT x int, INOUT y int) LANGUAGE plphp AS $$
    return array($x + $y, $x - $y);
$$;
CALL proc_ret(10, 4);
 x  | y 
----+---
 14 | 6
(1 row)

DROP PROCEDURE proc_one(int), proc_multi(int, text),
               proc_mixed(int, int), proc_ret(int, int);
